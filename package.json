{
  "name": "true-site-sync",
  "version": "1.5.74",
  "description": "True Site Sync — Construction Management Platform for Indian Contractors",
  "author": {
    "name": "True Site Sync",
    "email": "info@truesitesync.com",
    "url": "https://truesitesync.com"
  },
  "homepage": "https://truesitesync.com",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test \"tests/**/*.test.js\"",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.truesitesync.app",
    "productName": "True Site Sync",
    "copyright": "© 2026 True Site Sync. All rights reserved.",
    "publish": [{
      "provider": "github",
      "owner": "raghusoftware",
      "repo": "truesitesync",
      "releaseType": "release"
    }],
    "directories": {
      "output": "dist"
    },
    "files": [
      "app.html",
      "css/**/*",
      "js/**/*",
      "assets/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "publisherName": "True Site Sync",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "TrueSiteSync-Setup.${ext}",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "True Site Sync",
      "menuCategory": "Business",
      "license": "LICENSE.txt",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
